{
  "name": "new_schedule_app",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.13.0+sha512.88d94724d8f2e6c186744a5584c6e59ecac869ec7ba15e9cb4cd628e8dc7066820b2481d8ee3b51ea8da323a7378068aa58c556a3720d32b7c20a051d088363a",
  "engines": {
    "node": ">=22.13 <23"
  },
  "imports": {
    "#config/*": "./packages/config/*",
    "#contracts/*": "./packages/contracts/*",
    "#schemas/*": "./packages/schemas/*",
    "#utils/*": "./packages/utils/*"
  },
  "scripts": {
    "dev": "concurrently \"pnpm dev:frontend\" \"pnpm dev:backend\"",
    "dev:frontend": "vite --config vite.config.ts",
    "dev:backend": "tsx watch apps/backend/index.ts",
    "build:frontend": "vite build --config vite.config.ts",
    "build:backend": "vite build --config vite.config.ts --mode backend",
    "typecheck": "pnpm typecheck:frontend && pnpm typecheck:backend && pnpm typecheck:tools",
    "typecheck:frontend": "tsc -p tsconfig.frontend.json --noEmit",
    "typecheck:backend": "tsc -p tsconfig.backend.json --noEmit",
    "typecheck:tools": "tsc -p tsconfig.tools.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:frontend": "vitest run --project frontend",
    "test:backend": "vitest run --project backend",
    "test:integration": "vitest run --project backend apps/backend/index.test.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fullcalendar/core": "6.1.21",
    "@fullcalendar/daygrid": "6.1.21",
    "@fullcalendar/interaction": "6.1.21",
    "@fullcalendar/luxon3": "6.1.21",
    "@fullcalendar/react": "6.1.21",
    "@fullcalendar/timegrid": "6.1.21",
    "@hono/node-server": "2.0.9",
    "@mui/icons-material": "7.3.11",
    "@mui/material": "7.3.11",
    "@simplewebauthn/server": "13.3.2",
    "clsx": "^2.1.1",
    "dayjs": "1.11.21",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.30",
    "jose": "^6.2.3",
    "luxon": "^3.7.2",
    "pg": "8.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.18.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.2",
    "@types/luxon": "^3.7.2",
    "@types/node": "22.20.1",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "concurrently": "10.0.3",
    "drizzle-kit": "0.31.10",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "tailwindcss": "4.3.2",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
