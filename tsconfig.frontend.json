{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",

    "resolveJsonModule": true,

    "noEmit": true,
    "skipLibCheck": true,
    "types": ["vite/client"]
  },
  "include": [
    "apps/frontend/**/*.ts",
    "apps/frontend/**/*.tsx",
    "packages/**/*.ts",
    "apps/backend/config/env.ts"
  ],
  "exclude": ["node_modules", "dist", "apps/backend"]
}
